{
  "name": "ossguard-app",
  "version": "0.1.0",
  "description": "GitHub App that scans PRs for OpenSSF security best practices",
  "author": "Kiran Kumar Kotari <kirankotari@live.com>",
  "license": "Apache-2.0",
  "homepage": "https://github.com/kirankotari/ossguard-app",
  "repository": {
    "type": "git",
    "url": "https://github.com/kirankotari/ossguard-app.git"
  },
  "keywords": [
    "github-app",
    "openssf",
    "security",
    "scorecard",
    "slsa",
    "sbom",
    "supply-chain"
  ],
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "build:action": "tsc && ncc build dist/action.js -o dist/action-bundle && mv dist/action-bundle/index.js dist/action.js && rm -rf dist/action-bundle",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@actions/github": "^6.0.0",
    "js-yaml": "^4.1.0",
    "probot": "^13.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.6.2",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "@vercel/ncc": "^0.38.4",
    "eslint": "^9.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=20"
  }
}
